{
  "routes": [
    {
      "route": "/tenant-scan",
      "rewrite": "/tenant-scan.html"
    },
    {
      "route": "/executive-briefing",
      "rewrite": "/executive-briefing.html"
    },
    {
      "route": "/migration-playbook",
      "rewrite": "/migration-playbook.html"
    }
